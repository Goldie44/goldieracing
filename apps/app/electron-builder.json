{
  "appId": "com.f1manager.app",
  "productName": "F1 Manager",
  "directories": {
    "output": "release"
  },
  "files": ["dist/**/*", "package.json"],
  "extraResources": [
    {
      "from": "../web/dist",
      "to": "web"
    }
  ],
  "mac": {
    "category": "public.app-category.sports",
    "target": ["dmg", "zip"]
  },
  "win": {
    "target": ["nsis"]
  },
  "linux": {
    "target": ["AppImage"]
  }
}
